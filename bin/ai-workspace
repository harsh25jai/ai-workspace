#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const distPath = path.join(__dirname, '../dist/cli/index.js');
const devPath = path.join(__dirname, '../src/cli/index.ts');

if (fs.existsSync(distPath)) {
  require(distPath);
} else {
  // Fallback for dev mode
  require('ts-node').register();
  require(devPath);
}
